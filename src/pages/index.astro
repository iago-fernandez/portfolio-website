---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';

const directory = [
    {
        title: 'About Me',
        description: 'Technical trajectory, academic foundation, and core engineering philosophy.',
        link: '/about',
        icon: 'M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z'
    },
    {
        title: 'Experience',
        description: 'Professional background, internships, and algorithmic optimization research.',
        link: '/experience',
        icon: 'M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z'
    },
    {
        title: 'Projects',
        description: 'High-performance systems, concurrent computing, and infrastructure architectures.',
        link: '/projects',
        icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'
    }
];
---

<Layout title="Iago Fernandez | Systems Engineer" description="Systems Engineer specializing in high-performance infrastructure, concurrent architectures, and low-level performance.">
    <Hero />
    
    <section class="border-t border-gray-200 mt-12 w-full">
        <div class="mx-auto max-w-6xl px-12 py-12 animate-fade-in-up animation-delay-400">
            <h3 class="mb-8 text-xl font-bold tracking-tight text-gray-900">
                Explore Portfolio
            </h3>
            <div class="grid gap-6 sm:grid-cols-3">
                {directory.map((item) => (
                    <a href={item.link} class="group flex flex-col rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:border-blue-200 hover:shadow-md">
                        <div class="mb-4 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-blue-50 text-blue-600 transition-colors group-hover:bg-blue-600 group-hover:text-white">
                            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={item.icon} />
                            </svg>
                        </div>
                        <h4 class="text-lg font-bold text-gray-900 transition-colors group-hover:text-blue-600">
                            {item.title}
                        </h4>
                        <p class="mt-2 text-sm text-gray-600">
                            {item.description}
                        </p>
                    </a>
                ))}
            </div>
        </div>
    </section>
</Layout>