---
const currentYear = new Date().getFullYear();
const githubUrl = "https://github.com/iago-fernandez";
const linkedinUrl = "https://linkedin.com/in/iagofernandez-dev/";
---

<footer class="mt-auto border-t border-gray-200 bg-white py-10 shadow-[0_-4px_20px_rgba(0,0,0,0.02)]">
    <div class="mx-auto flex w-full max-w-7xl flex-col items-center justify-between px-6 sm:px-12 sm:flex-row">
        <p class="text-sm font-medium text-gray-500">
            &copy; {currentYear} Iago Fernandez. All rights reserved.
        </p>
        <div class="mt-4 flex gap-x-6 sm:mt-0">
            <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-gray-500 transition-colors hover:text-blue-600">
                GitHub
            </a>
            <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-gray-500 transition-colors hover:text-blue-600">
                LinkedIn
            </a>
        </div>
    </div>
</footer>