---
const currentYear = new Date().getFullYear();
const githubUrl = "https://github.com/iago-fernandez";
const linkedinUrl = "https://linkedin.com/in/iago-fernandez-perlo/";
---

<footer class="mt-auto border-t border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 py-10 shadow-[0_-4px_20px_rgba(0,0,0,0.02)] dark:shadow-[0_-4px_20px_rgba(0,0,0,0.1)] transition-colors duration-300">
    <div class="mx-auto flex w-full max-w-7xl flex-col items-center justify-between px-6 sm:px-12 sm:flex-row">
        <p class="text-sm font-medium text-gray-500 dark:text-zinc-400 transition-colors duration-300">
            &copy; {currentYear} Iago Fernandez. All rights reserved.
        </p>
        <div class="mt-4 flex gap-x-6 sm:mt-0">
            <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-gray-500 dark:text-zinc-400 transition-colors hover:text-blue-600 dark:hover:text-zinc-200">
                GitHub
            </a>
            <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="text-sm font-semibold text-gray-500 dark:text-zinc-400 transition-colors hover:text-blue-600 dark:hover:text-zinc-200">
                LinkedIn
            </a>
        </div>
    </div>
</footer>