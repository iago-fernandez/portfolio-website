---
const navLinks = [
    { name: 'About', url: '/#about' },
    { name: 'Experience', url: '/#experience' },
    { name: 'Projects', url: '/#projects' }
];
---

<header class="fixed top-0 z-50 w-full border-b border-gray-100 bg-gray-50/80 backdrop-blur-md">
    <nav class="mx-auto flex max-w-4xl items-center justify-between px-6 py-4" aria-label="Global">
        <a href="/" class="text-lg font-bold tracking-tight text-gray-900">
            IF.
        </a>
        <div class="flex gap-x-6">
            {navLinks.map((link) => (
                <a href={link.url} class="text-sm font-medium text-gray-600 transition-colors hover:text-gray-900">
                    {link.name}
                </a>
            ))}
        </div>
    </nav>
</header>