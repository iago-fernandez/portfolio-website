---
---

<section id="contact" class="py-20 animate-fade-in-up">
    <div class="grid gap-12 lg:grid-cols-2 items-start">
        
        <div class="flex flex-col h-full">
            <h2 class="mb-6 text-3xl font-bold tracking-tight text-gray-900 dark:text-zinc-100 sm:text-4xl transition-colors duration-300">
                Get in Touch
            </h2>
            <div class="space-y-6 text-base leading-relaxed text-gray-600 dark:text-zinc-400 transition-colors duration-300">
                <p>
                    I am actively seeking professional opportunities in high-performance computing, AI infrastructure, and systems engineering. I am always open to discussing new projects, roles, or technical challenges.
                </p>
                <p>
                    If you have architectural suggestions, optimizations, or wish to contribute to any of my open-source repositories, I highly encourage and welcome Pull Requests on GitHub. Collaborative engineering and code review are standards I deeply value.
                </p>
                <p>
                    Whether it is a formal job offer, a technical inquiry, or simply to connect, please feel free to reach out. Use the contact form to send a direct message, and I will ensure to respond as promptly as possible. Alternatively, you can find me on my professional networks below.
                </p>
            </div>
            
            <div class="mt-10 flex flex-wrap gap-4">
                <a href="https://github.com/iago-fernandez" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-md bg-white dark:bg-zinc-800 px-5 py-2.5 text-sm font-bold text-gray-900 dark:text-zinc-100 border border-gray-200 dark:border-zinc-700 shadow-sm hover:shadow-md hover:bg-gray-50 dark:hover:bg-zinc-700 transition-all duration-300 hover:-translate-y-1">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                    </svg>
                    GitHub
                </a>
                <a href="https://linkedin.com/in/iago-fernandez-perlo" target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center gap-2 rounded-md bg-white dark:bg-zinc-800 px-5 py-2.5 text-sm font-bold text-blue-700 dark:text-blue-400 border border-gray-200 dark:border-zinc-700 shadow-sm hover:shadow-md hover:bg-gray-50 dark:hover:bg-zinc-700 transition-all duration-300 hover:-translate-y-1">
                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                    </svg>
                    LinkedIn
                </a>
            </div>
        </div>

        <div class="flex flex-col h-full lg:mt-16">
            <div class="w-full rounded-xl border border-gray-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 p-8 sm:p-10 shadow-sm transition-all hover:shadow-md dark:hover:shadow-blue-900/10 duration-300">
                <form id="contact-form" class="space-y-6" novalidate autocomplete="off">
                    <div>
                        <label for="email" class="block text-sm font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">
                            Email Address
                        </label>
                        <input type="email" name="email" id="email" required class="mt-2 block w-full rounded-md border border-gray-300 dark:border-zinc-600 bg-transparent px-4 py-3 text-sm text-gray-900 dark:text-zinc-100 placeholder-gray-400 dark:placeholder-zinc-500 outline-none transition-all focus:border-blue-500 focus:ring-1 focus:ring-blue-500 dark:focus:border-blue-400 dark:focus:ring-blue-400" placeholder="your.email@example.com">
                    </div>
                    <div>
                        <label for="subject" class="block text-sm font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">
                            Subject
                        </label>
                        <input type="text" name="subject" id="subject" required class="mt-2 block w-full rounded-md border border-gray-300 dark:border-zinc-600 bg-transparent px-4 py-3 text-sm text-gray-900 dark:text-zinc-100 placeholder-gray-400 dark:placeholder-zinc-500 outline-none transition-all focus:border-blue-500 focus:ring-1 focus:ring-blue-500 dark:focus:border-blue-400 dark:focus:ring-blue-400" placeholder="Inquiry about...">
                    </div>
                    <div>
                        <label for="message" class="block text-sm font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">
                            Message
                        </label>
                        <textarea name="message" id="message" rows="5" required class="mt-2 block w-full resize-none rounded-md border border-gray-300 dark:border-zinc-600 bg-transparent px-4 py-3 text-sm text-gray-900 dark:text-zinc-100 placeholder-gray-400 dark:placeholder-zinc-500 outline-none transition-all focus:border-blue-500 focus:ring-1 focus:ring-blue-500 dark:focus:border-blue-400 dark:focus:ring-blue-400" placeholder="Hello Iago, ..."></textarea>
                    </div>
                    
                    <div id="turnstile-widget"></div>

                    <div id="form-status" class="hidden rounded-md p-4 text-sm font-bold transition-all duration-300"></div>

                    <button type="submit" id="submit-btn" class="mt-4 inline-flex w-full items-center justify-center rounded-md bg-blue-600 px-6 py-3.5 text-sm font-bold text-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:bg-blue-700 dark:bg-blue-500 dark:text-white dark:hover:bg-blue-400 hover:shadow-lg active:translate-y-0 cursor-pointer disabled:opacity-70 disabled:cursor-not-allowed">
                        <span id="btn-text">Send Message</span>
                        <svg id="btn-spinner" class="hidden h-5 w-5 animate-spin text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </button>
                </form>
            </div>
            
            <div class="mt-6 flex items-center justify-center gap-2 text-xs font-medium text-gray-500 dark:text-zinc-500 transition-colors duration-300 w-full px-2">
                <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                </svg>
                <span>Submissions are encrypted and routed directly to my private inbox.</span>
            </div>
        </div>

    </div>
</section>

<script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js?onload=onloadTurnstileCallback&render=explicit" async defer></script>

<script>
    document.addEventListener('astro:page-load', () => {
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
        const btnText = document.getElementById('btn-text');
        const btnSpinner = document.getElementById('btn-spinner');
        const formStatus = document.getElementById('form-status');
        const turnstileWidget = document.getElementById('turnstile-widget');

        if (!form || !submitBtn || !formStatus) return;

        if (form.dataset.initialized === 'true') return;
        form.dataset.initialized = 'true';

        let turnstileId: string | undefined;
        let isSubmitting = false;
        let currentToken: string | null = null;

        const updateStatus = (type: 'success' | 'error', message: string) => {
            formStatus.textContent = message;
            formStatus.className = 'rounded-md p-4 text-sm font-bold transition-all duration-300 ' + 
                (type === 'success' 
                    ? 'bg-green-50 text-green-800 border border-green-200 dark:bg-green-900/30 dark:text-green-300 dark:border-green-800'
                    : 'bg-red-50 text-red-800 border border-red-200 dark:bg-red-900/30 dark:text-red-300 dark:border-red-800');
            formStatus.classList.remove('hidden');
        };

        const toggleLoading = (loading: boolean) => {
            isSubmitting = loading;
            submitBtn.disabled = loading;
            if (loading) {
                btnText?.classList.add('hidden');
                btnSpinner?.classList.remove('hidden');
                formStatus.classList.add('hidden');
            } else {
                btnText?.classList.remove('hidden');
                btnSpinner?.classList.add('hidden');
            }
        };

        const renderTurnstile = () => {
            if ((window as any).turnstile && turnstileWidget && turnstileId === undefined) {
                turnstileId = (window as any).turnstile.render(turnstileWidget, {
                    sitekey: '0x4AAAAAACqH2g4WiqJ-5q1M',
                    size: 'invisible',
                    callback: (token: string) => {
                        currentToken = token;
                    },
                    'error-callback': () => {
                        currentToken = null;
                        updateStatus('error', 'Security verification failed. Please refresh the page.');
                    },
                    'expired-callback': () => {
                        currentToken = null;
                        if ((window as any).turnstile && turnstileId !== undefined) {
                            (window as any).turnstile.reset(turnstileId);
                        }
                    }
                });
            }
        };

        if ((window as any).turnstile) {
            renderTurnstile();
        } else {
            (window as any).onloadTurnstileCallback = renderTurnstile;
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            if (isSubmitting) return;

            if (!form.checkValidity()) {
                const emailInput = document.getElementById('email') as HTMLInputElement;
                const msg = !emailInput.validity.valid 
                    ? 'Please provide a valid email address.' 
                    : 'Please fill out all required fields.';
                updateStatus('error', msg);
                return;
            }

            if (!currentToken) {
                updateStatus('error', 'Verifying connection... Please wait a second and try again.');
                return;
            }
            
            toggleLoading(true);

            const formData = new FormData(form);
            formData.set('cf-turnstile-response', currentToken);

            try {
                const response = await fetch('https://portfolio-contact-api.iagofernandezperlo.workers.dev', {
                    method: 'POST',
                    body: formData
                });

                if (response.ok) {
                    updateStatus('success', 'Message sent successfully! I will get back to you soon.');
                    form.reset();
                } else {
                    throw new Error('Server rejected request');
                }
            } catch (error) {
                updateStatus('error', 'There was an error processing your message. Please try again later.');
            } finally {
                toggleLoading(false);
                currentToken = null;
                if ((window as any).turnstile && turnstileId !== undefined) {
                    (window as any).turnstile.reset(turnstileId);
                }
            }
        });
    });
</script>