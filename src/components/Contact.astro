<section class="flex flex-col items-center justify-center py-20 animate-fade-in-up">
    <div class="mb-10 text-center max-w-2xl mx-auto px-4">
        <h1 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-zinc-100 sm:text-4xl transition-colors duration-300">
            Get in touch
        </h1>
        <p class="mt-4 text-base text-gray-600 dark:text-zinc-400 transition-colors duration-300">
            I am actively seeking opportunities in high-performance computing, AI infrastructure, and systems engineering. Fill out the form below to send a direct message.
        </p>
    </div>

    <div class="w-full max-w-2xl rounded-xl border border-gray-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 p-8 sm:p-10 shadow-sm transition-all hover:shadow-md dark:hover:shadow-blue-900/10 duration-300">
        <form id="contact-form" class="space-y-6">
            <div>
                <label for="email" class="block text-sm font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">
                    Email Address
                </label>
                <input type="email" name="email" id="email" required class="mt-2 block w-full rounded-md border border-gray-300 dark:border-zinc-600 bg-transparent px-4 py-3 text-sm text-gray-900 dark:text-zinc-100 placeholder-gray-400 dark:placeholder-zinc-500 outline-none transition-all focus:border-gray-900 focus:ring-1 focus:ring-gray-900 dark:focus:border-zinc-300 dark:focus:ring-zinc-300" placeholder="your.email@example.com">
            </div>
            <div>
                <label for="subject" class="block text-sm font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">
                    Subject
                </label>
                <input type="text" name="subject" id="subject" required class="mt-2 block w-full rounded-md border border-gray-300 dark:border-zinc-600 bg-transparent px-4 py-3 text-sm text-gray-900 dark:text-zinc-100 placeholder-gray-400 dark:placeholder-zinc-500 outline-none transition-all focus:border-gray-900 focus:ring-1 focus:ring-gray-900 dark:focus:border-zinc-300 dark:focus:ring-zinc-300" placeholder="Inquiry about...">
            </div>
            <div>
                <label for="message" class="block text-sm font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">
                    Message
                </label>
                <textarea name="message" id="message" rows="6" required class="mt-2 block w-full resize-none rounded-md border border-gray-300 dark:border-zinc-600 bg-transparent px-4 py-3 text-sm text-gray-900 dark:text-zinc-100 placeholder-gray-400 dark:placeholder-zinc-500 outline-none transition-all focus:border-gray-900 focus:ring-1 focus:ring-gray-900 dark:focus:border-zinc-300 dark:focus:ring-zinc-300" placeholder="Hello Iago, ..."></textarea>
            </div>
            
            <div id="form-status" class="hidden rounded-md p-4 text-sm font-bold transition-all duration-300"></div>

            <button type="submit" id="submit-btn" class="mt-4 inline-flex w-full items-center justify-center rounded-md bg-zinc-900 px-6 py-3.5 text-sm font-bold text-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:bg-zinc-800 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200 hover:shadow-lg active:translate-y-0 cursor-pointer disabled:opacity-70 disabled:cursor-not-allowed">
                <span id="btn-text">Send Message</span>
                <svg id="btn-spinner" class="hidden h-5 w-5 animate-spin text-white dark:text-zinc-900" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                </svg>
            </button>
        </form>
    </div>

    <p class="mt-6 flex items-center justify-center gap-2 text-sm font-medium text-gray-500 dark:text-zinc-500 transition-colors duration-300 px-4 text-center">
        <svg class="h-4 w-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
        </svg>
        All submitted information is securely processed and maintained with strict confidentiality.
    </p>
</section>

<script>
    document.addEventListener('astro:page-load', () => {
        const form = document.getElementById('contact-form') as HTMLFormElement;
        const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
        const btnText = document.getElementById('btn-text');
        const btnSpinner = document.getElementById('btn-spinner');
        const formStatus = document.getElementById('form-status');

        if (form && submitBtn && btnText && btnSpinner && formStatus) {
            form.addEventListener('submit', async (e) => {
                e.preventDefault();
                
                submitBtn.disabled = true;
                if (btnText) btnText.classList.add('hidden');
                if (btnSpinner) btnSpinner.classList.remove('hidden');
                if (formStatus) {
                    formStatus.classList.add('hidden');
                    formStatus.className = 'hidden rounded-md p-4 text-sm font-bold transition-all duration-300';
                }

                const formData = new FormData(form);

                try {
                    const response = await fetch('https://portfolio-contact-api.iagofernandezperlo.workers.dev', {
                        method: 'POST',
                        body: formData
                    });

                    if (response.ok) {
                        if (formStatus) {
                            formStatus.textContent = 'Message sent successfully! I will get back to you soon.';
                            formStatus.classList.add('bg-green-50', 'text-green-800', 'border', 'border-green-200', 'dark:bg-green-900/30', 'dark:text-green-300', 'dark:border-green-800');
                            formStatus.classList.remove('hidden');
                        }
                        form.reset();
                    } else {
                        throw new Error('Server rejected request');
                    }
                } catch (error) {
                    if (formStatus) {
                        formStatus.textContent = 'There was an error sending your message. Please try again later.';
                        formStatus.classList.add('bg-red-50', 'text-red-800', 'border', 'border-red-200', 'dark:bg-red-900/30', 'dark:text-red-300', 'dark:border-red-800');
                        formStatus.classList.remove('hidden');
                    }
                } finally {
                    submitBtn.disabled = false;
                    if (btnText) btnText.classList.remove('hidden');
                    if (btnSpinner) btnSpinner.classList.add('hidden');
                }
            });
        }
    });
</script>