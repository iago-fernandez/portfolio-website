---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface ExperienceData {
    title: string;
    company: string;
    companyUrl?: string;
    period: string;
    description: string;
    details?: string;
    technologies?: string[];
}

const experiences: ExperienceData[] = [
    {
        title: t('exp.item1.title'),
        company: 'RAPOSa',
        companyUrl: 'https://raposa.usc.es/',
        period: t('exp.item1.period'),
        description: t('exp.item1.desc'),
        details: t('exp.item1.details'),
        technologies: ['C++', 'CMake', 'Python', 'GitLab', 'SOCP', 'IPOPT', 'Knitro', 'Mosek', 'Clarabel', 'CESGA']
    }
];
---

<section id="experience" class="py-20 animate-fade-in-up">
    <h2 class="mb-10 text-3xl font-bold tracking-tight text-gray-900 dark:text-zinc-100 sm:text-4xl transition-colors duration-300">
        {t('exp.title')}
    </h2>
    <div class="ml-3 space-y-8 border-l border-zinc-300 dark:border-zinc-700 transition-colors duration-300">
        {experiences.map((exp) => (
            <div class="relative pl-8">
                <div class="absolute -left-1.5 mt-1.5 h-3 w-3 rounded-full border border-white dark:border-zinc-900 bg-blue-600 dark:bg-blue-500 shadow-sm transition-colors duration-300"></div>
                <div class="mb-1 flex flex-col sm:flex-row sm:items-center sm:justify-between">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">{exp.title}</h3>
                    <time class="text-sm font-semibold text-gray-500 dark:text-zinc-400 transition-colors duration-300">{exp.period}</time>
                </div>
                {exp.companyUrl ? (
                    <a href={exp.companyUrl} target="_blank" rel="noopener noreferrer" class="group mb-3 inline-flex items-center text-sm font-bold text-blue-600 dark:text-blue-400 transition-colors duration-300">
                        <span class="border-b border-transparent group-hover:border-blue-600 dark:group-hover:border-blue-400 transition-colors">{exp.company}</span>
                        <svg class="ml-1 h-3.5 w-3.5 opacity-70 transition-opacity group-hover:opacity-100" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                    </a>
                ) : (
                    <p class="mb-3 text-sm font-bold text-blue-600 dark:text-blue-400 transition-colors duration-300">{exp.company}</p>
                )}
                <p class="text-base leading-relaxed text-gray-600 dark:text-zinc-400 transition-colors duration-300">{exp.description}</p>
                
                {exp.details && (
                    <details class="group mt-4">
                        <summary class="flex cursor-pointer items-center text-sm font-semibold text-gray-900 dark:text-zinc-300 transition-colors hover:text-blue-600 dark:hover:text-blue-400 focus:outline-none">
                            <span class="group-open:hidden">{t('exp.ui.view')}</span>
                            <span class="hidden group-open:inline">{t('exp.ui.hide')}</span>
                            <svg class="ml-1.5 h-4 w-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </summary>
                        <div class="mt-3 rounded-md bg-zinc-50 dark:bg-zinc-800 p-4 text-sm text-gray-600 dark:text-zinc-400 border border-zinc-100 dark:border-zinc-700 shadow-sm transition-colors duration-300">
                            <p class="leading-relaxed">{exp.details}</p>
                            {exp.technologies && (
                                <div class="mt-4 flex flex-wrap gap-2">
                                    {exp.technologies.map(tech => (
                                        <span class="rounded-md bg-white dark:bg-zinc-700/50 px-2.5 py-1 text-xs font-bold text-zinc-700 dark:text-zinc-300 border border-zinc-200 dark:border-zinc-600 transition-colors duration-300">
                                            {tech}
                                        </span>
                                    ))}
                                </div>
                            )}
                        </div>
                    </details>
                )}
            </div>
        ))}
    </div>
</section>