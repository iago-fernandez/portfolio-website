---
interface ExperienceData {
    title: string;
    company: string;
    companyUrl?: string;
    period: string;
    description: string;
    details?: string;
    technologies?: string[];
}

const experiences: ExperienceData[] = [
    {
        title: 'Software Engineering Intern',
        company: 'RAPOSa',
        companyUrl: 'https://raposa.usc.es/',
        period: 'October 2025 - Present',
        description: 'Developing low-level C++ interfaces for global polynomial optimization solvers and designing a new Second-Order Cone Programming (SOCP) input system, focusing on strict memory management and algorithmic efficiency.',
        details: 'RAPOSa is a state-of-the-art global polynomial optimization solver. My core responsibility involves engineering low-level C++ interfaces to seamlessly integrate powerful mathematical solvers, including IPOPT, Knitro, Mosek, and Clarabel. Additionally, I am contributing to the architecture by designing a new SOCP input system to tighten relaxations using advanced conic constraints. The C++ build system is orchestrated using CMake and Make, supported by Python scripting for workflow automation. Version control and continuous integration are managed through a self-hosted GitLab instance, allowing for unlimited, secure deployments and benchmarking directly on the CESGA (Galicia Supercomputing Center) infrastructure. The project is currently maintained in this private environment with a roadmap for a future open-source release. The ongoing advancements of this project will be presented by my tutors, Julio González Díaz and Brais González Rodríguez, at the 24th Conference of the International Federation of Operational Research Societies (IFORS 2026) in Vienna, Austria.',
        technologies: ['C++', 'CMake', 'Python', 'GitLab', 'SOCP', 'IPOPT', 'Knitro', 'Mosek', 'Clarabel', 'CESGA']
    }
];
---

<section id="experience" class="py-20 animate-fade-in-up">
    <h2 class="mb-10 text-3xl font-bold tracking-tight text-gray-900 dark:text-zinc-100 sm:text-4xl transition-colors duration-300">
        Experience
    </h2>
    <div class="ml-3 space-y-8 border-l border-zinc-300 dark:border-zinc-700 transition-colors duration-300">
        {experiences.map((exp) => (
            <div class="relative pl-8">
                <div class="absolute -left-1.5 mt-1.5 h-3 w-3 rounded-full border border-white dark:border-zinc-900 bg-blue-600 dark:bg-blue-500 shadow-sm transition-colors duration-300"></div>
                <div class="mb-1 flex flex-col sm:flex-row sm:items-center sm:justify-between">
                    <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">{exp.title}</h3>
                    <time class="text-sm font-semibold text-gray-500 dark:text-zinc-400 transition-colors duration-300">{exp.period}</time>
                </div>
                {exp.companyUrl ? (
                    <a href={exp.companyUrl} target="_blank" rel="noopener noreferrer" class="mb-3 inline-block text-sm font-bold text-blue-600 dark:text-blue-400 hover:underline transition-colors duration-300">
                        {exp.company}
                    </a>
                ) : (
                    <p class="mb-3 text-sm font-bold text-blue-600 dark:text-blue-400 transition-colors duration-300">{exp.company}</p>
                )}
                <p class="text-base leading-relaxed text-gray-600 dark:text-zinc-400 transition-colors duration-300">{exp.description}</p>
                
                {exp.details && (
                    <details class="group mt-4">
                        <summary class="flex cursor-pointer items-center text-sm font-semibold text-gray-900 dark:text-zinc-300 transition-colors hover:text-blue-600 dark:hover:text-blue-400 focus:outline-none">
                            <span class="group-open:hidden">View technical details</span>
                            <span class="hidden group-open:inline">Hide technical details</span>
                            <svg class="ml-1 h-4 w-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </summary>
                        <div class="mt-3 rounded-md bg-white dark:bg-zinc-800 p-4 text-sm text-gray-600 dark:text-zinc-400 border border-gray-100 dark:border-zinc-700 shadow-sm transition-colors duration-300">
                            <p class="leading-relaxed">{exp.details}</p>
                            {exp.technologies && (
                                <div class="mt-4 flex flex-wrap gap-2">
                                    {exp.technologies.map(tech => (
                                        <span class="rounded-md bg-gray-50 dark:bg-zinc-700/50 px-2.5 py-1 text-xs font-bold text-gray-700 dark:text-zinc-300 border border-gray-200 dark:border-zinc-600 transition-colors duration-300">
                                            {tech}
                                        </span>
                                    ))}
                                </div>
                            )}
                        </div>
                    </details>
                )}
            </div>
        ))}
    </div>
</section>