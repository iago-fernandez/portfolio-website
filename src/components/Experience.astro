---
interface ExperienceData {
    title: string;
    company: string;
    period: string;
    description: string;
    details?: string;
    technologies?: string[];
}

const experiences: ExperienceData[] = [
    {
        title: 'Software Engineering Intern',
        company: 'RAPOSa',
        period: 'Upcoming',
        description: 'Research and development focused on algorithmic optimization and high-performance computing infrastructure.',
        details: 'Implementing solutions to maximize temporal and spatial efficiency. Interfacing directly with low-level C++ APIs for advanced mathematical solvers including IPOPT, Knitro, Mosek, and Clarabel to optimize complex computational models.',
        technologies: ['C++', 'IPOPT', 'Knitro', 'Mosek', 'Clarabel']
    }
];
---

<section id="experience" class="py-20">
    <div class="animate-fade-in-up">
        <h2 class="mb-10 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            Experience
        </h2>
        <div class="ml-3 space-y-8 border-l border-gray-200">
            {experiences.map((exp) => (
                <div class="relative pl-8">
                    <div class="absolute -left-1.5 mt-1.5 h-3 w-3 rounded-full border border-white bg-gray-900"></div>
                    <div class="mb-1 flex flex-col sm:flex-row sm:items-center sm:justify-between">
                        <h3 class="text-lg font-semibold text-gray-900">{exp.title}</h3>
                        <time class="text-sm font-medium text-gray-500">{exp.period}</time>
                    </div>
                    <p class="mb-2 text-sm font-medium text-gray-600">{exp.company}</p>
                    <p class="text-base text-gray-600">{exp.description}</p>
                    
                    {exp.details && (
                        <details class="group mt-3">
                            <summary class="flex cursor-pointer items-center text-sm font-medium text-blue-600 transition-colors hover:text-blue-800 focus:outline-none">
                                <span class="mr-1">View technical details</span>
                                <svg class="h-4 w-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                </svg>
                            </summary>
                            <div class="mt-3 text-sm text-gray-600">
                                <p class="leading-relaxed">{exp.details}</p>
                                {exp.technologies && (
                                    <div class="mt-4 flex flex-wrap gap-2">
                                        {exp.technologies.map(tech => (
                                            <span class="rounded-md bg-gray-100 px-2.5 py-1 text-xs font-semibold text-gray-800 border border-gray-200">
                                                {tech}
                                            </span>
                                        ))}
                                    </div>
                                )}
                            </div>
                        </details>
                    )}
                </div>
            ))}
        </div>
    </div>
</section>