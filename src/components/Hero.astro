---
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.png';

const githubUrl = "https://github.com/iago-fernandez";
const linkedinUrl = "https://linkedin.com/in/iago-fernandez-dev";
const cvUrl = "/resume.pdf";
---

<section class="flex min-h-[70vh] flex-col-reverse items-center justify-between gap-12 pt-24 pb-12 sm:flex-row">
    <div class="flex-1 animate-fade-in-up">
        <h1 class="text-5xl font-extrabold tracking-tight text-gray-900 sm:text-6xl">
            Iago Fernandez
        </h1>
        <h2 class="mt-4 text-2xl font-medium text-gray-600 sm:text-3xl">
            Dual BSc in Mathematics & Computer Engineering
        </h2>
        <div class="mt-6 max-w-lg animation-delay-200">
            <p class="text-lg leading-relaxed text-gray-600">
                Specializing in high-performance computing, concurrent architectures, and AI infrastructure. Focused on maximizing temporal and spatial efficiency in low-level systems.
            </p>
        </div>
        <div class="mt-10 flex gap-4 animation-delay-400">
            <a 
                href={cvUrl}
                target="_blank"
                rel="noopener noreferrer" 
                class="inline-flex items-center justify-center rounded-md bg-gray-900 px-6 py-3 text-sm font-medium text-white shadow-sm transition-colors hover:bg-gray-800"
            >
                View Curriculum
            </a>
            <a 
                href={githubUrl}
                target="_blank"
                rel="noopener noreferrer" 
                class="inline-flex items-center justify-center rounded-md border border-gray-200 bg-white px-6 py-3 text-sm font-medium text-gray-900 shadow-sm transition-colors hover:bg-gray-50 hover:text-gray-900"
            >
                GitHub
            </a>
        </div>
    </div>
    <div class="flex-1 flex justify-center sm:justify-end animate-fade-in-up animation-delay-200">
        <div class="relative flex h-64 w-64 items-center justify-center overflow-hidden rounded-full border border-gray-200 bg-gray-50 shadow-sm sm:h-80 sm:w-80">
            <Image 
                src={profileImage} 
                alt="Iago Fernandez" 
                class="h-full w-full object-cover"
                loading="eager"
                width={320}
                height={320}
            />
        </div>
    </div>
</section>