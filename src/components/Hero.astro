---
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.png';

const githubUrl = "https://github.com/iago-fernandez";
const linkedinUrl = "https://linkedin.com/in/iagofernandez-dev/";
const cvUrl = "/resume.pdf";
---

<section class="relative w-full overflow-hidden pt-8 pb-12">
    <div class="mx-auto max-w-7xl px-6 sm:px-12 relative z-10">
        <div class="grid min-h-[60vh] grid-cols-1 items-center gap-y-12 gap-x-8 lg:grid-cols-12">
            <div class="animate-fade-in-up lg:col-span-10 pr-16">
                <h1 class="text-5xl font-extrabold tracking-tight text-gray-900 sm:text-6xl lg:text-7xl">
                    Iago Fernández Perlo
                </h1>
                <h2 class="mt-4 text-2xl font-semibold text-gray-700 sm:text-3xl whitespace-nowrap">
                    Dual BSc in Mathematics & Computer Engineering
                </h2>
                <div class="mt-6 max-w-3xl animation-delay-200">
                    <p class="text-lg leading-relaxed text-gray-600">
                        Specializing in high-performance computing, concurrent architectures, and AI infrastructure. Focused on maximizing temporal and spatial efficiency in low-level systems.
                    </p>
                </div>
                <div class="mt-10 flex flex-wrap gap-4 animation-delay-400">
                    <a href={cvUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-md bg-gray-900 px-6 py-3 text-sm font-medium text-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:bg-gray-800 hover:shadow-lg active:translate-y-0">
                        View Curriculum
                    </a>
                    <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-md border border-gray-200 bg-white px-6 py-3 text-sm font-medium text-gray-900 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-gray-300 hover:bg-gray-50 hover:shadow-lg active:translate-y-0">
                        GitHub
                    </a>
                    <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-md border border-gray-200 bg-white px-6 py-3 text-sm font-medium text-gray-900 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-gray-300 hover:bg-gray-50 hover:shadow-lg active:translate-y-0">
                        LinkedIn
                    </a>
                </div>
            </div>
            
            <div class="flex justify-center animate-fade-in-up animation-delay-200 lg:col-span-2 lg:justify-end">
                <div class="relative flex h-64 w-64 flex-shrink-0 items-center justify-center overflow-hidden rounded-full border-4 border-white bg-white shadow-md transition-all duration-500 ease-out hover:scale-[1.02] hover:shadow-2xl hover:shadow-blue-900/20 sm:h-80 sm:w-80">
                    <Image src={profileImage} alt="Iago Fernández Perlo" class="h-full w-full object-cover transition-transform duration-700 ease-out hover:scale-105" loading="eager" width={320} height={320}/>
                </div>
            </div>
        </div>
    </div>
</section>