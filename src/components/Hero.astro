---
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.png';

const githubUrl = "https://github.com/iago-fernandez";
const linkedinUrl = "https://linkedin.com/in/iagofernandez-dev/";
const cvUrl = "/resume.pdf";
---

<section id="hero-container" class="relative w-full overflow-hidden pt-8 pb-20 bg-zinc-50 dark:bg-zinc-900 transition-colors duration-300">
    <canvas id="network-canvas" class="absolute inset-0 z-0 h-full w-full opacity-80 pointer-events-none dark:opacity-70 transition-opacity duration-300"></canvas>
    <div class="mx-auto max-w-7xl px-6 sm:px-12 relative z-10">
        <div class="grid min-h-[85vh] grid-cols-1 items-center gap-y-12 gap-x-8 lg:grid-cols-12">
            <div class="order-2 min-w-0 animate-fade-in-up lg:order-1 lg:col-span-7 xl:col-span-8 lg:pr-8">
                <h1 class="text-4xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-100 sm:text-5xl lg:text-6xl xl:text-7xl transition-colors duration-300">
                    Iago Fernández Perlo
                </h1>
                <h2 class="mt-4 text-xl font-semibold text-zinc-700 dark:text-zinc-300 sm:text-2xl xl:text-3xl transition-colors duration-300">
                    Dual BSc in Mathematics & Computer Engineering
                </h2>
                <div class="mt-6 max-w-3xl animation-delay-200">
                    <p class="text-base leading-relaxed text-zinc-600 dark:text-zinc-400 sm:text-lg transition-colors duration-300 text-pretty">
                        Bridging theoretical mathematics and low-level software engineering to build high-performance computing systems, concurrent architectures, and AI infrastructure. My primary focus lies in maximizing temporal and spatial efficiency within complex computational&nbsp;models.
                    </p>
                </div>
                <div class="mt-10 flex flex-col sm:flex-row gap-4 animation-delay-400 w-full sm:w-auto">
                    <a href={cvUrl} target="_blank" rel="noopener noreferrer" class="inline-flex w-full sm:w-auto items-center justify-center rounded-md bg-zinc-900 px-6 py-3 text-sm font-medium text-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:bg-zinc-800 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200 hover:shadow-lg active:translate-y-0">
                        View Curriculum
                    </a>
                    <div class="flex flex-row gap-4 w-full sm:w-auto">
                        <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex flex-1 sm:flex-none items-center justify-center rounded-md border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-6 py-3 text-sm font-medium text-zinc-900 dark:text-zinc-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-zinc-300 dark:hover:border-zinc-600 hover:bg-zinc-50 dark:hover:bg-zinc-700 hover:shadow-lg active:translate-y-0">
                            GitHub
                        </a>
                        <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="inline-flex flex-1 sm:flex-none items-center justify-center rounded-md border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-6 py-3 text-sm font-medium text-zinc-900 dark:text-zinc-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-zinc-300 dark:hover:border-zinc-600 hover:bg-zinc-50 dark:hover:bg-zinc-700 hover:shadow-lg active:translate-y-0">
                            LinkedIn
                        </a>
                    </div>
                </div>
            </div>
            
            <div class="order-1 flex justify-center animate-fade-in-up animation-delay-200 lg:order-2 lg:col-span-5 xl:col-span-4 lg:justify-end">
                <div class="relative flex h-56 w-56 flex-shrink-0 items-center justify-center overflow-hidden rounded-full border-4 border-white dark:border-zinc-700 bg-white dark:bg-zinc-700 shadow-md transition-all duration-500 ease-out hover:scale-[1.02] hover:shadow-2xl hover:shadow-blue-900/20 dark:hover:shadow-blue-500/10 sm:h-72 sm:w-72 lg:h-80 lg:w-80">
                    <Image src={profileImage} alt="Iago Fernandez" class="h-full w-full object-cover transition-transform duration-700 ease-out hover:scale-105" loading="eager" width={320} height={320}/>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('astro:page-load', () => {
        const canvas = document.getElementById('network-canvas') as HTMLCanvasElement;
        const container = document.getElementById('hero-container');
        if (!canvas || !container) return;
        
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        let width = container.offsetWidth;
        let height = container.offsetHeight;
        canvas.width = width;
        canvas.height = height;

        let particles: Particle[] = [];
        const mouse = { x: -9999, y: -9999 };
        let needsResize = false;

        const resizeObserver = new ResizeObserver(() => {
            needsResize = true;
        });
        resizeObserver.observe(container);

        const updateMousePosition = (clientX: number, clientY: number) => {
            const rect = container.getBoundingClientRect();
            mouse.x = clientX - rect.left;
            mouse.y = clientY - rect.top;
        };

        const resetMousePosition = () => {
            mouse.x = -9999;
            mouse.y = -9999;
        };

        container.addEventListener('mousemove', (e) => updateMousePosition(e.clientX, e.clientY));
        container.addEventListener('mouseleave', resetMousePosition);
        container.addEventListener('touchstart', (e) => updateMousePosition(e.touches[0].clientX, e.touches[0].clientY), { passive: true });
        container.addEventListener('touchmove', (e) => updateMousePosition(e.touches[0].clientX, e.touches[0].clientY), { passive: true });
        container.addEventListener('touchend', resetMousePosition);

        class Particle {
            x: number;
            y: number;
            vx: number;
            vy: number;
            size: number;

            constructor(isNew = false) {
                this.x = isNew ? Math.random() * width : Math.random() * (container.offsetWidth || 1000);
                this.y = isNew ? Math.random() * height : Math.random() * (container.offsetHeight || 1000);
                this.vx = (Math.random() - 0.5) * 0.6;
                this.vy = (Math.random() - 0.5) * 0.6;
                this.size = Math.random() * 2.5 + 1;
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;
                
                if (this.x < 0) {
                    this.x = 0;
                    this.vx *= -1;
                } else if (this.x > width) {
                    this.x = width;
                    this.vx *= -1;
                }

                if (this.y < 0) {
                    this.y = 0;
                    this.vy *= -1;
                } else if (this.y > height) {
                    this.y = height;
                    this.vy *= -1;
                }
            }

            draw() {
                if (!ctx) return;
                const isDark = document.documentElement.classList.contains('dark');
                ctx.fillStyle = isDark ? 'rgba(96, 165, 250, 0.45)' : 'rgba(37, 99, 235, 0.45)';
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        let connectionRadius = 150;
        let mouseInteractionRadius = 220;
        let connDivisor = 500;
        let mouseDivisor = 550;

        const updateCanvasConfiguration = () => {
            const currentWidth = window.innerWidth;
            const scale = Math.max(0.6, Math.min(1, currentWidth / 1200));
            
            const targetCount = Math.floor(120 * scale);
            connectionRadius = 150 * scale;
            mouseInteractionRadius = 220 * scale;
            connDivisor = 500 * scale;
            mouseDivisor = 550 * scale;

            if (particles.length > targetCount) {
                particles.splice(targetCount);
            }
            while (particles.length < targetCount) {
                particles.push(new Particle(true));
            }
        };

        updateCanvasConfiguration();

        const animate = () => {
            if (!ctx) return;

            if (needsResize) {
                width = container.offsetWidth;
                height = container.offsetHeight;
                canvas.width = width;
                canvas.height = height;

                updateCanvasConfiguration();

                particles.forEach(p => {
                    if (p.x > width) p.x = Math.random() * width;
                    if (p.y > height) p.y = Math.random() * height;
                });

                needsResize = false;
            }

            ctx.clearRect(0, 0, width, height);
            
            for (let i = 0; i < particles.length; i++) {
                particles[i].update();
                particles[i].draw();

                const dxMouse = mouse.x - particles[i].x;
                const dyMouse = mouse.y - particles[i].y;
                const distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);
                
                const isDark = document.documentElement.classList.contains('dark');

                if (distMouse < mouseInteractionRadius) {
                    const alpha = Math.max(0, 0.45 - (distMouse / mouseDivisor));
                    ctx.strokeStyle = isDark ? `rgba(96, 165, 250, ${alpha * 0.9})` : `rgba(37, 99, 235, ${alpha})`;
                    ctx.lineWidth = isDark ? 1.5 : 2.0;
                    ctx.beginPath();
                    ctx.moveTo(particles[i].x, particles[i].y);
                    ctx.lineTo(mouse.x, mouse.y);
                    ctx.stroke();
                }

                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const distance = Math.sqrt(dx * dx + dy * dy);

                    if (distance < connectionRadius) {
                        const alpha = Math.max(0, 0.35 - (distance / connDivisor));
                        ctx.strokeStyle = isDark ? `rgba(96, 165, 250, ${alpha * 0.8})` : `rgba(37, 99, 235, ${alpha})`;
                        ctx.lineWidth = isDark ? 1.0 : 1.5;
                        ctx.beginPath();
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(animate);
        }
        animate();
    });
</script>