---
import { Image } from 'astro:assets';
import profileImage from '../assets/profile.png';

const githubUrl = "https://github.com/iago-fernandez";
const linkedinUrl = "https://linkedin.com/in/iagofernandez-dev/";
const cvUrl = "/resume.pdf";
---

<section id="hero-container" class="relative w-full overflow-hidden pt-8 pb-20">
    <canvas id="network-canvas" class="absolute inset-0 z-0 h-full w-full opacity-80 pointer-events-none dark:opacity-70 transition-opacity duration-300"></canvas>

    <div class="mx-auto max-w-7xl px-6 sm:px-12 relative z-10">
        <div class="grid min-h-[85vh] grid-cols-1 items-center gap-y-12 gap-x-8 lg:grid-cols-12">
            <div class="order-2 min-w-0 animate-fade-in-up lg:order-1 lg:col-span-7 xl:col-span-8 lg:pr-8">
                <h1 class="text-4xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-100 sm:text-5xl lg:text-6xl xl:text-7xl transition-colors duration-300">
                    Iago Fernández Perlo
                </h1>
                <h2 class="mt-4 text-xl font-semibold text-zinc-700 dark:text-zinc-300 sm:text-2xl xl:text-3xl transition-colors duration-300">
                    Dual BSc in Mathematics & Computer Engineering
                </h2>
                <div class="mt-6 max-w-3xl animation-delay-200">
                    <p class="text-base leading-relaxed text-zinc-600 dark:text-zinc-400 sm:text-lg transition-colors duration-300">
                        Specializing in high-performance computing, concurrent architectures, and AI infrastructure. Focused on maximizing temporal and spatial efficiency in low-level systems.
                    </p>
                </div>
                <div class="mt-10 flex flex-wrap gap-4 animation-delay-400">
                    <a href={cvUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-md bg-zinc-900 px-6 py-3 text-sm font-medium text-white shadow-sm transition-all duration-300 hover:-translate-y-1 hover:bg-zinc-800 dark:bg-zinc-100 dark:text-zinc-900 dark:hover:bg-zinc-200 hover:shadow-lg active:translate-y-0">
                        View Curriculum
                    </a>
                    <a href={githubUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-md border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-6 py-3 text-sm font-medium text-zinc-900 dark:text-zinc-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-zinc-300 dark:hover:border-zinc-600 hover:bg-zinc-50 dark:hover:bg-zinc-700 hover:shadow-lg active:translate-y-0">
                        GitHub
                    </a>
                    <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center justify-center rounded-md border border-zinc-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 px-6 py-3 text-sm font-medium text-zinc-900 dark:text-zinc-200 shadow-sm transition-all duration-300 hover:-translate-y-1 hover:border-zinc-300 dark:hover:border-zinc-600 hover:bg-zinc-50 dark:hover:bg-zinc-700 hover:shadow-lg active:translate-y-0">
                        LinkedIn
                    </a>
                </div>
            </div>
            
            <div class="order-1 flex justify-center animate-fade-in-up animation-delay-200 lg:order-2 lg:col-span-5 xl:col-span-4 lg:justify-end">
                <div class="relative flex h-56 w-56 flex-shrink-0 items-center justify-center overflow-hidden rounded-full border-4 border-white dark:border-zinc-700 bg-white dark:bg-zinc-700 shadow-md transition-all duration-500 ease-out hover:scale-[1.02] hover:shadow-2xl hover:shadow-blue-900/20 dark:hover:shadow-blue-500/10 sm:h-72 sm:w-72 lg:h-80 lg:w-80">
                    <Image src={profileImage} alt="Iago Fernández Perlo" class="h-full w-full object-cover transition-transform duration-700 ease-out hover:scale-105" loading="eager" width={320} height={320}/>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    document.addEventListener('astro:page-load', () => {
        const canvas = document.getElementById('network-canvas') as HTMLCanvasElement;
        const container = document.getElementById('hero-container');
        if (!canvas || !container) return;
        
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        let width = 0;
        let height = 0;
        let particles: Particle[] = [];
        const mouse = { x: -9999, y: -9999 };

        const resize = () => {
            width = canvas.width = container.offsetWidth;
            height = canvas.height = container.offsetHeight;
        };

        resize();

        const resizeObserver = new ResizeObserver(() => {
            resize();
        });
        resizeObserver.observe(container);

        container.addEventListener('mousemove', (e) => {
            const rect = container.getBoundingClientRect();
            mouse.x = e.clientX - rect.left;
            mouse.y = e.clientY - rect.top;
        });

        container.addEventListener('mouseleave', () => {
            mouse.x = -9999;
            mouse.y = -9999;
        });

        class Particle {
            x: number;
            y: number;
            vx: number;
            vy: number;
            size: number;

            constructor() {
                this.x = Math.random() * width;
                this.y = Math.random() * height;
                this.vx = (Math.random() - 0.5) * 0.6;
                this.vy = (Math.random() - 0.5) * 0.6;
                this.size = Math.random() * 2.5 + 1;
            }

            update() {
                this.x += this.vx;
                this.y += this.vy;
                
                if (this.x < 0 || this.x > width) this.vx *= -1;
                if (this.y < 0 || this.y > height) this.vy *= -1;

                if (this.x < 0) this.x = 0;
                if (this.x > width) this.x = width;
                if (this.y < 0) this.y = 0;
                if (this.y > height) this.y = height;
            }

            draw() {
                if(!ctx) return;
                const isDark = document.documentElement.classList.contains('dark');
                ctx.fillStyle = isDark ? 'rgba(191, 219, 254, 0.45)' : 'rgba(37, 99, 235, 0.45)';
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        particles = Array.from({ length: 100 }, () => new Particle());

        const animate = () => {
            if(!ctx) return;
            ctx.clearRect(0, 0, width, height);
            
            for (let i = 0; i < particles.length; i++) {
                particles[i].update();
                particles[i].draw();

                const dxMouse = mouse.x - particles[i].x;
                const dyMouse = mouse.y - particles[i].y;
                const distMouse = Math.sqrt(dxMouse * dxMouse + dyMouse * dyMouse);
                
                const isDark = document.documentElement.classList.contains('dark');

                if (distMouse < 220) {
                    const alpha = Math.max(0, 0.45 - distMouse / 550);
                    ctx.strokeStyle = isDark ? `rgba(191, 219, 254, ${alpha * 0.9})` : `rgba(37, 99, 235, ${alpha})`;
                    ctx.lineWidth = isDark ? 1.5 : 2.0;
                    ctx.beginPath();
                    ctx.moveTo(particles[i].x, particles[i].y);
                    ctx.lineTo(mouse.x, mouse.y);
                    ctx.stroke();
                }

                for (let j = i + 1; j < particles.length; j++) {
                    const dx = particles[i].x - particles[j].x;
                    const dy = particles[i].y - particles[j].y;
                    const distance = Math.sqrt(dx * dx + dy * dy);

                    if (distance < 150) {
                        const alpha = Math.max(0, 0.35 - distance / 500);
                        ctx.strokeStyle = isDark ? `rgba(191, 219, 254, ${alpha * 0.8})` : `rgba(37, 99, 235, ${alpha})`;
                        ctx.lineWidth = isDark ? 1.0 : 1.5;
                        ctx.beginPath();
                        ctx.moveTo(particles[i].x, particles[i].y);
                        ctx.lineTo(particles[j].x, particles[j].y);
                        ctx.stroke();
                    }
                }
            }
            requestAnimationFrame(animate);
        }
        animate();
    });
</script>