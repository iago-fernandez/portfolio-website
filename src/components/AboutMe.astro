---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const education = [
    {
        institution: 'Universidade de Santiago de Compostela',
        degree: t('about.edu.degree1'),
        years: '2020 - 2027'
    },
    {
        institution: 'University of Lodz',
        degree: t('about.edu.degree2'),
        years: '2025 - 2026'
    }
];

const coreLanguages = [
    { name: 'C', icon: '/icons/c.svg' },
    { name: 'C++', icon: '/icons/cplusplus.svg' },
    { name: 'Rust', icon: '/icons/rust.svg' },
    { name: 'Assembly', icon: '/icons/assembly.svg' },
    { name: 'Fortran', icon: '/icons/fortran.svg' },
    { name: 'Python', icon: '/icons/python.svg' },
    { name: 'MATLAB', icon: '/icons/matlab.svg' },
    { name: 'R', icon: '/icons/r.svg' },
    { name: 'Maple', icon: '/icons/maple.svg' },
    { name: 'AMPL', icon: '/icons/ampl.svg' },
    { name: 'SQL', icon: '/icons/sql.svg' },
    { name: 'Java', icon: '/icons/java.svg' },
    { name: 'C#', icon: '/icons/csharp.svg' }
];

const infrastructure = [
    { name: 'Linux', icon: '/icons/linux.svg' },
    { name: 'Bash', icon: '/icons/bash.svg' },
    { name: 'Docker', icon: '/icons/docker.svg' },
    { name: 'CMake', icon: '/icons/cmake.svg' },
    { name: 'Make', icon: '/icons/make.svg' },
    { name: 'Ninja', icon: '/icons/ninja.svg' },
    { name: 'Git', icon: '/icons/git.svg' },
    { name: 'GitHub', icon: '/icons/github.svg' },
    { name: 'GitLab', icon: '/icons/gitlab.svg' },
    { name: 'Actions', icon: '/icons/githubactions.svg' },
    { name: 'PostgreSQL', icon: '/icons/postgresql.svg' },
    { name: 'MySQL', icon: '/icons/mysql.svg' },
    { name: 'Nginx', icon: '/icons/nginx.svg' },
    { name: 'Apache', icon: '/icons/apache.svg' }
];

const additionalTech = [
    { name: 'NumPy', icon: '/icons/numpy.svg' },
    { name: 'Pandas', icon: '/icons/pandas.svg' },
    { name: 'OpenGL', icon: '/icons/opengl.svg' },
    { name: 'Unity', icon: '/icons/unity.svg' },
    { name: 'Godot', icon: '/icons/godot.svg' },
    { name: 'LaTeX', icon: '/icons/latex.svg' },
    { name: 'Figma', icon: '/icons/figma.svg' },
    { name: 'TypeScript', icon: '/icons/typescript.svg' },
    { name: 'JavaScript', icon: '/icons/javascript.svg' },
    { name: 'Astro', icon: '/icons/astro.svg' },
    { name: 'Next.js', icon: '/icons/nextjs.svg' },
    { name: 'Tailwind', icon: '/icons/tailwindcss.svg' },
    { name: 'HTML5', icon: '/icons/html5.svg' },
    { name: 'CSS3', icon: '/icons/css3.svg' }
];

const duplicatedCore = [...coreLanguages, ...coreLanguages, ...coreLanguages, ...coreLanguages];
const duplicatedInfra = [...infrastructure, ...infrastructure, ...infrastructure, ...infrastructure];
const duplicatedExtra = [...additionalTech, ...additionalTech, ...additionalTech, ...additionalTech];
---

<section class="py-20 animate-fade-in-up">
    <h2 class="mb-12 text-3xl font-bold tracking-tight text-gray-900 dark:text-zinc-100 sm:text-4xl transition-colors duration-300">
        {t('about.title')}
    </h2>
    
    <div class="grid gap-12 lg:grid-cols-3">
        <div class="space-y-6 text-base leading-relaxed text-gray-600 dark:text-zinc-400 lg:col-span-2 transition-colors duration-300">
            <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">{t('about.bg.title')}</h3>
            <p>{t('about.bg.p1')}</p>
            <p>{t('about.bg.p2')}</p>
            <p>{t('about.bg.p3')}</p>
            <p>{t('about.bg.p4')}</p>
            <p>{t('about.bg.p5')}</p>
        </div>

        <div class="space-y-6">
            <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">{t('about.academic.title')}</h3>
            <div class="space-y-6">
                {education.map(edu => (
                    <div class="rounded-lg border border-gray-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 p-5 shadow-sm transition-all hover:shadow-md dark:hover:shadow-blue-900/10">
                        <p class="text-sm font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">{edu.institution}</p>
                        <p class="mt-1 text-sm font-medium text-blue-600 dark:text-blue-400 transition-colors duration-300">{edu.degree}</p>
                        <p class="mt-2 text-xs font-semibold text-gray-500 dark:text-zinc-500 transition-colors duration-300">{edu.years}</p>
                    </div>
                ))}
            </div>
        </div>
    </div>
    
    <div class="mt-16 mb-6">
        <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">
            {t('about.core.title')}
        </h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400 transition-colors duration-300">
            {t('about.core.desc')}
        </p>
    </div>
    
    <div class="w-[100vw] relative left-[50%] right-[50%] -ml-[50vw] -mr-[50vw] border-y border-zinc-300 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 py-0 transition-colors duration-300">
        <div class="carousel-container relative w-full overflow-hidden flex h-28 group/slider">
            <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-32 bg-gradient-to-r from-zinc-50 dark:from-zinc-900 to-transparent"></div>
            <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-32 bg-gradient-to-l from-zinc-50 dark:from-zinc-900 to-transparent"></div>
            
            <button aria-label="Scroll left" class="btn-left group/btn absolute h-full top-0 bottom-0 left-0 z-20 w-12 flex items-center justify-center bg-gradient-to-r from-zinc-200/60 to-transparent dark:from-zinc-800/40 opacity-100 lg:opacity-0 transition-all duration-300 hover:from-blue-300/70 dark:hover:from-blue-900/40 lg:group-hover/slider:opacity-100 cursor-pointer border-none outline-none">
                <svg class="h-6 w-6 text-zinc-500 dark:text-zinc-400 transition-colors duration-300 group-hover/btn:text-blue-600 dark:group-hover/btn:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
                </svg>
            </button>

            <div class="animate-carousel-core flex w-max items-center h-full">
                {duplicatedCore.map(tech => (
                    <div class="icon-card group/icon select-none relative flex flex-col items-center justify-center cursor-pointer min-w-[100px] h-full mr-16 transform-gpu [&.is-hovered>div]:-translate-y-3 [&.is-hovered>span]:opacity-100">
                        <div class="pointer-events-none flex h-full w-full items-center justify-center transition-transform duration-300">
                            <div class="h-[48px] w-[48px] bg-gray-400 dark:bg-zinc-600 transition-colors duration-300 [.is-hovered_&]:bg-blue-600 dark:[.is-hovered_&]:bg-blue-400" style={`-webkit-mask-image: url('${tech.icon}'); mask-image: url('${tech.icon}'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;`}></div>
                        </div>
                        <span class="pointer-events-none absolute bottom-4 text-xs font-bold text-gray-500 dark:text-zinc-400 opacity-0 transition-opacity duration-300">
                            {tech.name}
                        </span>
                    </div>
                ))}
            </div>
        </div>
    </div>

    <div class="mt-12 mb-6">
        <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">
            {t('about.sys.title')}
        </h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400 transition-colors duration-300">
            {t('about.sys.desc')}
        </p>
    </div>
    
    <div class="w-[100vw] relative left-[50%] right-[50%] -ml-[50vw] -mr-[50vw] border-y border-zinc-300 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 py-0 transition-colors duration-300">
        <div class="carousel-container relative w-full overflow-hidden flex h-28 group/slider">
            <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-32 bg-gradient-to-r from-zinc-50 dark:from-zinc-900 to-transparent"></div>
            <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-32 bg-gradient-to-l from-zinc-50 dark:from-zinc-900 to-transparent"></div>
            
            <button aria-label="Scroll right" class="btn-right group/btn absolute h-full top-0 bottom-0 right-0 z-20 w-12 flex items-center justify-center bg-gradient-to-l from-zinc-200/60 to-transparent dark:from-zinc-800/40 opacity-100 lg:opacity-0 transition-all duration-300 hover:from-blue-300/70 dark:hover:from-blue-900/40 lg:group-hover/slider:opacity-100 cursor-pointer border-none outline-none">
                <svg class="h-6 w-6 text-zinc-500 dark:text-zinc-400 transition-colors duration-300 group-hover/btn:text-blue-600 dark:group-hover/btn:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" />
                </svg>
            </button>

            <div class="animate-carousel-infra flex w-max items-center h-full">
                {duplicatedInfra.map(tech => (
                    <div class="icon-card group/icon select-none relative flex flex-col items-center justify-center cursor-pointer min-w-[100px] h-full mr-16 transform-gpu [&.is-hovered>div]:-translate-y-3 [&.is-hovered>span]:opacity-100">
                        <div class="pointer-events-none flex h-full w-full items-center justify-center transition-transform duration-300">
                            <div class="h-[48px] w-[48px] bg-gray-400 dark:bg-zinc-600 transition-colors duration-300 [.is-hovered_&]:bg-blue-600 dark:[.is-hovered_&]:bg-blue-400" style={`-webkit-mask-image: url('${tech.icon}'); mask-image: url('${tech.icon}'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;`}></div>
                        </div>
                        <span class="pointer-events-none absolute bottom-4 text-xs font-bold text-gray-500 dark:text-zinc-400 opacity-0 transition-opacity duration-300">
                            {tech.name}
                        </span>
                    </div>
                ))}
            </div>
        </div>
    </div>

    <div class="mt-12 mb-6">
        <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">
            {t('about.vers.title')}
        </h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400 transition-colors duration-300">
            {t('about.vers.desc')}
        </p>
    </div>
    
    <div class="w-[100vw] relative left-[50%] right-[50%] -ml-[50vw] -mr-[50vw] border-y border-zinc-300 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 py-0 transition-colors duration-300">
        <div class="carousel-container relative w-full overflow-hidden flex h-28 group/slider">
            <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-32 bg-gradient-to-r from-zinc-50 dark:from-zinc-900 to-transparent"></div>
            <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-32 bg-gradient-to-l from-zinc-50 dark:from-zinc-900 to-transparent"></div>
            
            <button aria-label="Scroll left" class="btn-left group/btn absolute h-full top-0 bottom-0 left-0 z-20 w-12 flex items-center justify-center bg-gradient-to-r from-zinc-200/60 to-transparent dark:from-zinc-800/40 opacity-100 lg:opacity-0 transition-all duration-300 hover:from-blue-300/70 dark:hover:from-blue-900/40 lg:group-hover/slider:opacity-100 cursor-pointer border-none outline-none">
                <svg class="h-6 w-6 text-zinc-500 dark:text-zinc-400 transition-colors duration-300 group-hover/btn:text-blue-600 dark:group-hover/btn:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
                </svg>
            </button>

            <div class="animate-carousel-extra flex w-max items-center h-full">
                {duplicatedExtra.map(tech => (
                    <div class="icon-card group/icon select-none relative flex flex-col items-center justify-center cursor-pointer min-w-[100px] h-full mr-16 transform-gpu [&.is-hovered>div]:-translate-y-3 [&.is-hovered>span]:opacity-100">
                        <div class="pointer-events-none flex h-full w-full items-center justify-center transition-transform duration-300">
                            <div class="h-[48px] w-[48px] bg-gray-400 dark:bg-zinc-600 transition-colors duration-300 [.is-hovered_&]:bg-blue-600 dark:[.is-hovered_&]:bg-blue-400" style={`-webkit-mask-image: url('${tech.icon}'); mask-image: url('${tech.icon}'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;`}></div>
                        </div>
                        <span class="pointer-events-none absolute bottom-4 text-xs font-bold text-gray-500 dark:text-zinc-400 opacity-0 transition-opacity duration-300">
                            {tech.name}
                        </span>
                    </div>
                ))}
            </div>
        </div>
    </div>

</section>

<script>
    document.addEventListener('astro:page-load', () => {
        let mouseX = 0;
        let mouseY = 0;
        let isPointerOverContainer = false;
        let activeHoverCard = null;
        let rafId = null;

        const updatePointerCoordinates = (e) => {
            if (e.touches && e.touches.length > 0) {
                mouseX = e.touches[0].clientX;
                mouseY = e.touches[0].clientY;
            } else {
                mouseX = e.clientX;
                mouseY = e.clientY;
            }
        };

        const executeHoverDetectionLoop = () => {
            if (!isPointerOverContainer) {
                if (activeHoverCard) {
                    activeHoverCard.classList.remove('is-hovered');
                    activeHoverCard = null;
                }
                rafId = null;
                return;
            }

            const topElement = document.elementFromPoint(mouseX, mouseY);
            const foundCard = topElement ? topElement.closest('.icon-card') : null;

            if (foundCard !== activeHoverCard) {
                if (activeHoverCard) activeHoverCard.classList.remove('is-hovered');
                if (foundCard) foundCard.classList.add('is-hovered');
                activeHoverCard = foundCard;
            }

            rafId = requestAnimationFrame(executeHoverDetectionLoop);
        };

        const carousels = document.querySelectorAll('.carousel-container');

        carousels.forEach(container => {
            const track = container.querySelector('.animate-carousel-core, .animate-carousel-infra, .animate-carousel-extra');
            const leftBtn = container.querySelector('.btn-left');
            const rightBtn = container.querySelector('.btn-right');
            
            if (!track) return;

            let isAccelerating = false;

            const updatePlaybackRate = () => {
                const anims = track.getAnimations();
                if (anims.length === 0) return;

                let rate = 1.0;
                if (isAccelerating) {
                    rate = 4.0;
                } else if (isPointerOverContainer) {
                    rate = 0.5;
                }

                anims.forEach(anim => {
                    anim.playbackRate = rate;
                });
            };

            const startHoverTracking = (e) => {
                isPointerOverContainer = true;
                updatePointerCoordinates(e);
                updatePlaybackRate();
                if (!rafId) {
                    rafId = requestAnimationFrame(executeHoverDetectionLoop);
                }
            };

            const stopHoverTracking = () => {
                isPointerOverContainer = false;
                updatePlaybackRate();
            };

            container.addEventListener('pointerenter', startHoverTracking);
            container.addEventListener('pointermove', updatePointerCoordinates);
            container.addEventListener('pointerleave', stopHoverTracking);

            const startAccelerating = (e) => {
                if (e.cancelable) e.preventDefault();
                e.stopPropagation();
                isAccelerating = true;
                updatePlaybackRate();
            };

            const stopAccelerating = (e) => {
                if (e.cancelable) e.preventDefault();
                e.stopPropagation();
                isAccelerating = false;
                updatePlaybackRate();
            };

            const btn = leftBtn || rightBtn;
            if (btn) {
                btn.addEventListener('pointerdown', startAccelerating);
                btn.addEventListener('pointerup', stopAccelerating);
                btn.addEventListener('pointerleave', stopAccelerating);
                btn.addEventListener('pointercancel', stopAccelerating);
            }
        });
        
        document.addEventListener('astro:before-swap', () => {
            if (rafId) {
                cancelAnimationFrame(rafId);
                rafId = null;
            }
        }, { once: true });
    });
</script>

<style>
    @keyframes carousel-left {
        0% { transform: translate3d(0, 0, 0); }
        100% { transform: translate3d(-50%, 0, 0); }
    }
    @keyframes carousel-right {
        0% { transform: translate3d(-50%, 0, 0); }
        100% { transform: translate3d(0, 0, 0); }
    }
    .animate-carousel-core {
        animation: carousel-left 65s linear infinite;
        will-change: transform;
    }
    .animate-carousel-infra {
        animation: carousel-right 70s linear infinite;
        will-change: transform;
    }
    .animate-carousel-extra {
        animation: carousel-left 70s linear infinite;
        will-change: transform;
    }
    .icon-card {
        -webkit-user-select: none;
        user-select: none;
        -webkit-user-drag: none;
    }
</style>