                        <p class="mt-1 text-sm font-medium text-blue-600 dark:text-blue-400 transition-colors duration-300">{edu.degree}</p>
                        <p class="mt-2 text-xs font-semibold text-gray-500 dark:text-zinc-500 transition-colors duration-300">{edu.years}</p>
                    </div>
                ))}
            </div>
        </div>
    </div>
    
    <div class="mt-16 mb-6">
        <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">
            Core Languages & Mathematical Tools
        </h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400 transition-colors duration-300">
            The foundational syntax utilized for high-performance execution, memory management, and rigorous mathematical modeling.
        </p>
    </div>
    
    <div class="w-[100vw] relative left-[50%] right-[50%] -ml-[50vw] -mr-[50vw] border-y border-zinc-300 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 py-0 transition-colors duration-300">
