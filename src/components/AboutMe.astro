---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const education = [
    {
        institution: 'Universidade de Santiago de Compostela',
        degree: t('about.edu.degree1'),
        years: '2020 - 2027'
    },
    {
        institution: 'University of Lodz',
        degree: t('about.edu.degree2'),
        years: '2025 - 2026'
    }
];

const coreLanguages = [
    { name: 'C', icon: '/icons/c.svg' },
    { name: 'C++', icon: '/icons/cplusplus.svg' },
    { name: 'Rust', icon: '/icons/rust.svg' },
    { name: 'Assembly', icon: '/icons/assembly.svg' },
    { name: 'Fortran', icon: '/icons/fortran.svg' },
    { name: 'Python', icon: '/icons/python.svg' },
    { name: 'MATLAB', icon: '/icons/matlab.svg' },
    { name: 'R', icon: '/icons/r.svg' },
    { name: 'Maple', icon: '/icons/maple.svg' },
    { name: 'AMPL', icon: '/icons/ampl.svg' },
    { name: 'SQL', icon: '/icons/sql.svg' },
    { name: 'Java', icon: '/icons/java.svg' },
    { name: 'C#', icon: '/icons/csharp.svg' }
];

const infrastructure = [
    { name: 'Linux', icon: '/icons/linux.svg' },
    { name: 'Bash', icon: '/icons/bash.svg' },
    { name: 'Docker', icon: '/icons/docker.svg' },
    { name: 'CMake', icon: '/icons/cmake.svg' },
    { name: 'Make', icon: '/icons/make.svg' },
    { name: 'Ninja', icon: '/icons/ninja.svg' },
    { name: 'Git', icon: '/icons/git.svg' },
    { name: 'GitHub', icon: '/icons/github.svg' },
    { name: 'GitLab', icon: '/icons/gitlab.svg' },
    { name: 'Actions', icon: '/icons/githubactions.svg' },
    { name: 'PostgreSQL', icon: '/icons/postgresql.svg' },
    { name: 'MySQL', icon: '/icons/mysql.svg' },
    { name: 'Nginx', icon: '/icons/nginx.svg' },
    { name: 'Apache', icon: '/icons/apache.svg' }
];

const additionalTech = [
    { name: 'NumPy', icon: '/icons/numpy.svg' },
    { name: 'Pandas', icon: '/icons/pandas.svg' },
    { name: 'OpenGL', icon: '/icons/opengl.svg' },
    { name: 'Unity', icon: '/icons/unity.svg' },
    { name: 'Godot', icon: '/icons/godot.svg' },
    { name: 'LaTeX', icon: '/icons/latex.svg' },
    { name: 'Figma', icon: '/icons/figma.svg' },
    { name: 'TypeScript', icon: '/icons/typescript.svg' },
    { name: 'JavaScript', icon: '/icons/javascript.svg' },
    { name: 'Astro', icon: '/icons/astro.svg' },
    { name: 'Next.js', icon: '/icons/nextjs.svg' },
    { name: 'Tailwind', icon: '/icons/tailwindcss.svg' },
    { name: 'HTML5', icon: '/icons/html5.svg' },
    { name: 'CSS3', icon: '/icons/css3.svg' }
];

const duplicatedCore = [...coreLanguages, ...coreLanguages, ...coreLanguages, ...coreLanguages];
const duplicatedInfra = [...infrastructure, ...infrastructure, ...infrastructure, ...infrastructure];
const duplicatedExtra = [...additionalTech, ...additionalTech, ...additionalTech, ...additionalTech];
---

<section class="py-20 animate-fade-in-up">
    <h2 class="mb-12 text-3xl font-bold tracking-tight text-gray-900 dark:text-zinc-100 sm:text-4xl transition-colors duration-300">
        {t('about.title')}
    </h2>
    
    <div class="grid gap-12 lg:grid-cols-3">
        <div class="space-y-6 text-base leading-relaxed text-gray-600 dark:text-zinc-400 lg:col-span-2 transition-colors duration-300">
            <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">{t('about.bg.title')}</h3>
            <p>{t('about.bg.p1')}</p>
            <p>{t('about.bg.p2')}</p>
            <p>{t('about.bg.p3')}</p>
            <p>{t('about.bg.p4')}</p>
            <p>{t('about.bg.p5')}</p>
        </div>

        <div class="space-y-6">
            <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">{t('about.academic.title')}</h3>
            <div class="space-y-6">
                {education.map(edu => (
                    <div class="rounded-lg border border-gray-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 p-5 shadow-sm transition-all hover:shadow-md dark:hover:shadow-blue-900/10">
                        <p class="text-sm font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">{edu.institution}</p>
                        <p class="mt-1 text-sm font-medium text-blue-600 dark:text-blue-400 transition-colors duration-300">{edu.degree}</p>
                        <p class="mt-2 text-xs font-semibold text-gray-500 dark:text-zinc-500 transition-colors duration-300">{edu.years}</p>
                    </div>
                ))}
            </div>
        </div>
    </div>
    
    <div class="mt-16 mb-6">
        <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">{t('about.core.title')}</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400 transition-colors duration-300">{t('about.core.desc')}</p>
    </div>
    
    <div class="carousel-container relative border-y border-zinc-300 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 py-0 transition-colors duration-300 h-28 overflow-hidden flex w-[100vw] max-w-[100vw]" style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw);">
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-32 bg-gradient-to-r from-zinc-50 dark:from-zinc-900 to-transparent"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-32 bg-gradient-to-l from-zinc-50 dark:from-zinc-900 to-transparent"></div>
        
        <button aria-label="Scroll left" class="action-btn cursor-pointer btn-left absolute h-full top-0 bottom-0 left-0 z-20 w-12 flex items-center justify-center bg-gradient-to-r from-zinc-200/60 to-transparent dark:from-zinc-800/40 opacity-100 lg:opacity-0 transition-all duration-300 hover:from-blue-300/70 dark:hover:from-blue-900/40 border-none outline-none">
            <svg class="pointer-events-none h-6 w-6 text-zinc-500 dark:text-zinc-400 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
            </svg>
        </button>

        <div class="animate-carousel-track flex w-max items-center h-full" data-duration="65000" data-direction="left">
            {duplicatedCore.map(tech => (
                <div class="icon-card select-none relative flex flex-col items-center justify-center cursor-pointer min-w-[100px] shrink-0 h-full mr-16">
                    <div class="icon-box pointer-events-none flex h-full w-full items-center justify-center transition-transform duration-300">
                        <div class="icon-mask h-[48px] w-[48px] bg-gray-400 dark:bg-zinc-600 transition-colors duration-300" style={`-webkit-mask-image: url('${tech.icon}'); mask-image: url('${tech.icon}'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;`}></div>
                    </div>
                    <span class="icon-label pointer-events-none absolute bottom-4 text-xs font-bold text-gray-500 dark:text-zinc-400 opacity-0 transition-opacity duration-300">{tech.name}</span>
                </div>
            ))}
        </div>
    </div>

    <div class="mt-12 mb-6">
        <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">{t('about.sys.title')}</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400 transition-colors duration-300">{t('about.sys.desc')}</p>
    </div>
    
    <div class="carousel-container relative border-y border-zinc-300 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 py-0 transition-colors duration-300 h-28 overflow-hidden flex w-[100vw] max-w-[100vw]" style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw);">
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-32 bg-gradient-to-r from-zinc-50 dark:from-zinc-900 to-transparent"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-32 bg-gradient-to-l from-zinc-50 dark:from-zinc-900 to-transparent"></div>
        
        <button aria-label="Scroll right" class="action-btn cursor-pointer btn-right absolute h-full top-0 bottom-0 right-0 z-20 w-12 flex items-center justify-center bg-gradient-to-l from-zinc-200/60 to-transparent dark:from-zinc-800/40 opacity-100 lg:opacity-0 transition-all duration-300 hover:from-blue-300/70 dark:hover:from-blue-900/40 border-none outline-none">
            <svg class="pointer-events-none h-6 w-6 text-zinc-500 dark:text-zinc-400 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" />
            </svg>
        </button>

        <div class="animate-carousel-track flex w-max items-center h-full" data-duration="70000" data-direction="right">
            {duplicatedInfra.map(tech => (
                <div class="icon-card select-none relative flex flex-col items-center justify-center cursor-pointer min-w-[100px] shrink-0 h-full mr-16">
                    <div class="icon-box pointer-events-none flex h-full w-full items-center justify-center transition-transform duration-300">
                        <div class="icon-mask h-[48px] w-[48px] bg-gray-400 dark:bg-zinc-600 transition-colors duration-300" style={`-webkit-mask-image: url('${tech.icon}'); mask-image: url('${tech.icon}'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;`}></div>
                    </div>
                    <span class="icon-label pointer-events-none absolute bottom-4 text-xs font-bold text-gray-500 dark:text-zinc-400 opacity-0 transition-opacity duration-300">{tech.name}</span>
                </div>
            ))}
        </div>
    </div>

    <div class="mt-12 mb-6">
        <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">{t('about.vers.title')}</h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400 transition-colors duration-300">{t('about.vers.desc')}</p>
    </div>
    
    <div class="carousel-container relative border-y border-zinc-300 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 py-0 transition-colors duration-300 h-28 overflow-hidden flex w-[100vw] max-w-[100vw]" style="margin-left: calc(50% - 50vw); margin-right: calc(50% - 50vw);">
        <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-32 bg-gradient-to-r from-zinc-50 dark:from-zinc-900 to-transparent"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-32 bg-gradient-to-l from-zinc-50 dark:from-zinc-900 to-transparent"></div>
        
        <button aria-label="Scroll left" class="action-btn cursor-pointer btn-left absolute h-full top-0 bottom-0 left-0 z-20 w-12 flex items-center justify-center bg-gradient-to-r from-zinc-200/60 to-transparent dark:from-zinc-800/40 opacity-100 lg:opacity-0 transition-all duration-300 hover:from-blue-300/70 dark:hover:from-blue-900/40 border-none outline-none">
            <svg class="pointer-events-none h-6 w-6 text-zinc-500 dark:text-zinc-400 transition-colors duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
            </svg>
        </button>

        <div class="animate-carousel-track flex w-max items-center h-full" data-duration="70000" data-direction="left">
            {duplicatedExtra.map(tech => (
                <div class="icon-card select-none relative flex flex-col items-center justify-center cursor-pointer min-w-[100px] shrink-0 h-full mr-16">
                    <div class="icon-box pointer-events-none flex h-full w-full items-center justify-center transition-transform duration-300">
                        <div class="icon-mask h-[48px] w-[48px] bg-gray-400 dark:bg-zinc-600 transition-colors duration-300" style={`-webkit-mask-image: url('${tech.icon}'); mask-image: url('${tech.icon}'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;`}></div>
                    </div>
                    <span class="icon-label pointer-events-none absolute bottom-4 text-xs font-bold text-gray-500 dark:text-zinc-400 opacity-0 transition-opacity duration-300">{tech.name}</span>
                </div>
            ))}
        </div>
    </div>
</section>

<script>
    document.addEventListener('astro:page-load', () => {
        const containers = document.querySelectorAll('.carousel-container');
        if (containers.length === 0) return;

        const pageController = new AbortController();
        document.addEventListener('astro:before-swap', () => pageController.abort(), { once: true });

        const isTouchDevice = window.matchMedia("(pointer: coarse)").matches;

        containers.forEach(container => {
            const track = container.querySelector('.animate-carousel-track');
            const btnLeft = container.querySelector('.btn-left');
            const btnRight = container.querySelector('.btn-right');
            const btn = btnLeft || btnRight;
            
            if (!track) return;

            const durationMs = parseInt(track.getAttribute('data-duration') || '70000', 10);
            const isRight = track.getAttribute('data-direction') === 'right';

            const transformStart = isRight ? 'translate3d(-50%, 0, 0)' : 'translate3d(0, 0, 0)';
            const transformEnd = isRight ? 'translate3d(0, 0, 0)' : 'translate3d(-50%, 0, 0)';

            const animation = track.animate(
                [
                    { transform: transformStart },
                    { transform: transformEnd }
                ],
                { duration: durationMs, iterations: Infinity, easing: 'linear' }
            );

            let isHoveringContainer = false;
            let isAccelerating = false;
            let hoveredIcon = null;

            const syncAnimation = () => {
                let targetRate = 1.0;
                
                if (isAccelerating) targetRate = 4.0;
                else if (isHoveringContainer) targetRate = 0.5;

                if (animation.playbackRate !== targetRate) {
                    animation.playbackRate = targetRate;
                }
            };

            if (btn) {
                btn.addEventListener('pointerdown', (e) => {
                    if (e.pointerType === 'mouse' && e.button !== 0) return;
                    btn.setPointerCapture(e.pointerId);
                    isAccelerating = true;
                    btn.classList.add('is-pressed');
                    syncAnimation();
                });

                const releasePointer = (e) => {
                    if (btn.hasPointerCapture(e.pointerId)) {
                        btn.releasePointerCapture(e.pointerId);
                    }
                    if (!isAccelerating) return;
                    isAccelerating = false;
                    btn.classList.remove('is-pressed');
                    syncAnimation();
                };

                btn.addEventListener('pointerup', releasePointer);
                btn.addEventListener('pointercancel', releasePointer);
                btn.addEventListener('contextmenu', e => e.preventDefault());
            }

            if (!isTouchDevice) {
                let localMouseX = -100;
                let localMouseY = -100;

                container.addEventListener('pointermove', (e) => {
                    localMouseX = e.clientX;
                    localMouseY = e.clientY;
                });

                container.addEventListener('pointerenter', () => {
                    isHoveringContainer = true;
                    syncAnimation();
                });
                
                container.addEventListener('pointerleave', () => {
                    isHoveringContainer = false;
                    syncAnimation();
                });

                const tick = () => {
                    if (!container.isConnected) return;

                    let currentHover = null;
                    if (isHoveringContainer && !isAccelerating) {
                        const topEls = document.elementsFromPoint(localMouseX, localMouseY);
                        for (let el of topEls) {
                            if (el.tagName === 'BUTTON' || el.closest('button')) break;
                            if (el.classList.contains('icon-card')) {
                                currentHover = el;
                                break;
                            }
                        }
                    }

                    if (hoveredIcon && hoveredIcon !== currentHover) {
                        hoveredIcon.classList.remove('is-hovered');
                    }
                    
                    hoveredIcon = currentHover;
                    if (hoveredIcon) {
                        hoveredIcon.classList.add('is-hovered');
                    }

                    requestAnimationFrame(tick);
                };
                requestAnimationFrame(tick);
            } else {
                const icons = Array.from(track.querySelectorAll('.icon-card'));
                icons.forEach(icon => {
                    icon.addEventListener('pointerdown', (e) => {
                        e.stopPropagation();
                        icons.forEach(c => c.classList.remove('is-hovered'));
                        icon.classList.add('is-hovered');
                        setTimeout(() => icon.classList.remove('is-hovered'), 2500);
                    });
                });
                document.addEventListener('pointerdown', () => {
                    icons.forEach(c => c.classList.remove('is-hovered'));
                }, { signal: pageController.signal });
            }
        });
    });
</script>

<style>
    .animate-carousel-track {
        will-change: transform;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
        -webkit-transform-style: preserve-3d;
        transform-style: preserve-3d;
        perspective: 1000px;
    }

    .action-btn {
        touch-action: none;
        -webkit-touch-callout: none;
        -webkit-user-select: none;
        user-select: none;
        -webkit-tap-highlight-color: transparent;
    }

    .icon-card {
        -webkit-user-select: none;
        user-select: none;
        -webkit-user-drag: none;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
        transform: translateZ(0);
    }
    
    .icon-card.is-hovered .icon-box {
        transform: translateY(-0.75rem);
    }
    
    .icon-card.is-hovered .icon-mask {
        background-color: rgb(37, 99, 235) !important;
    }
    
    .icon-card.is-hovered .icon-label {
        opacity: 1 !important;
    }
    
    .action-btn.is-pressed {
        opacity: 1 !important;
    }
    
    .action-btn.is-pressed.btn-left {
        background-image: linear-gradient(to right, rgba(96, 165, 250, 0.8), transparent) !important;
    }
    
    .action-btn.is-pressed.btn-right {
        background-image: linear-gradient(to left, rgba(96, 165, 250, 0.8), transparent) !important;
    }

    .action-btn.is-pressed svg {
        color: rgb(29, 78, 216) !important; 
        transform: scale(1.1);
        transition: transform 150ms ease;
    }

    @media (hover: hover) and (pointer: fine) {
        .carousel-container:hover .action-btn {
            opacity: 1 !important;
            transition: opacity 300ms ease;
        }
    }

    @media (prefers-color-scheme: dark) {
        .icon-card.is-hovered .icon-mask {
            background-color: rgb(96, 165, 250) !important;
        }

        .action-btn.is-pressed.btn-left {
            background-image: linear-gradient(to right, rgba(30, 64, 175, 0.8), transparent) !important;
        }
        
        .action-btn.is-pressed.btn-right {
            background-image: linear-gradient(to left, rgba(30, 64, 175, 0.8), transparent) !important;
        }
        
        .action-btn.is-pressed svg {
            color: rgb(147, 197, 253) !important;
        }
    }
</style>