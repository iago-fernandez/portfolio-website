</section>

<script>
    document.addEventListener('astro:page-load', () => {
        let mouseX = 0;
        let mouseY = 0;
        let isPointerOverContainer = false;
        let activeHoverCard = null;
        let rafId = null;

        const updatePointerCoordinates = (e) => {
            if (e.touches && e.touches.length > 0) {
                mouseX = e.touches[0].clientX;
                mouseY = e.touches[0].clientY;
            } else {
                mouseX = e.clientX;
                mouseY = e.clientY;
            }
        };

        const executeHoverDetectionLoop = () => {
            if (!isPointerOverContainer) {
                if (activeHoverCard) {
                    activeHoverCard.classList.remove('is-hovered');
                    activeHoverCard = null;
                }
                rafId = null;
                return;
            }

            const topElement = document.elementFromPoint(mouseX, mouseY);
            const foundCard = topElement ? topElement.closest('.icon-card') : null;

            if (foundCard !== activeHoverCard) {
                if (activeHoverCard) activeHoverCard.classList.remove('is-hovered');
                if (foundCard) foundCard.classList.add('is-hovered');
                activeHoverCard = foundCard;
            }

            rafId = requestAnimationFrame(executeHoverDetectionLoop);
        };

        const carousels = document.querySelectorAll('.carousel-container');

        carousels.forEach(container => {
            const track = container.querySelector('.animate-carousel-core, .animate-carousel-infra, .animate-carousel-extra');
            const leftBtn = container.querySelector('.btn-left');
            const rightBtn = container.querySelector('.btn-right');
            
            if (!track) return;

            let isAccelerating = false;

            const updatePlaybackRate = () => {
                const anims = track.getAnimations();
                if (anims.length === 0) return;

                let rate = 1.0;
                if (isAccelerating) {
                    rate = 4.0;
                } else if (isPointerOverContainer) {
                    rate = 0.5;
                }

                anims.forEach(anim => {
                    anim.playbackRate = rate;
                });
            };

            const startHoverTracking = (e) => {
                isPointerOverContainer = true;
                updatePointerCoordinates(e);
                updatePlaybackRate();
                if (!rafId) {
                    rafId = requestAnimationFrame(executeHoverDetectionLoop);
                }
            };

            const stopHoverTracking = () => {
                isPointerOverContainer = false;
                updatePlaybackRate();
            };

            container.addEventListener('pointerenter', startHoverTracking);
            container.addEventListener('pointermove', updatePointerCoordinates);
            container.addEventListener('pointerleave', stopHoverTracking);

            const startAccelerating = (e) => {
                if (e.cancelable) e.preventDefault();
                e.stopPropagation();
                isAccelerating = true;
                updatePlaybackRate();
            };

            const stopAccelerating = (e) => {
                if (e.cancelable) e.preventDefault();
                e.stopPropagation();
                isAccelerating = false;
                updatePlaybackRate();
            };

            const btn = leftBtn || rightBtn;
            if (btn) {
                btn.addEventListener('pointerdown', startAccelerating);
                btn.addEventListener('pointerup', stopAccelerating);
                btn.addEventListener('pointerleave', stopAccelerating);
                btn.addEventListener('pointercancel', stopAccelerating);
            }
        });
        
        document.addEventListener('astro:before-swap', () => {
            if (rafId) {
                cancelAnimationFrame(rafId);
                rafId = null;
            }
        }, { once: true });
    });
</script>

<style>
    @keyframes carousel-left {
        0% { transform: translate3d(0, 0, 0); }
        100% { transform: translate3d(-50%, 0, 0); }
    }
    @keyframes carousel-right {
        0% { transform: translate3d(-50%, 0, 0); }
        100% { transform: translate3d(0, 0, 0); }
    }
    .animate-carousel-core {
        animation: carousel-left 65s linear infinite;
        will-change: transform;
    }
    .animate-carousel-infra {
        animation: carousel-right 70s linear infinite;
        will-change: transform;
    }
    .animate-carousel-extra {
        animation: carousel-left 70s linear infinite;
        will-change: transform;
    }
    .icon-card {
        -webkit-user-select: none;
        user-select: none;
        -webkit-user-drag: none;
    }
</style>