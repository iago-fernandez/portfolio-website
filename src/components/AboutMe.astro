    </div>

    <div class="mt-12 mb-6">
        <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">
            Systems, Infrastructure & Compilation
        </h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400 transition-colors duration-300">
            The architectural environments, build systems, and orchestration tools utilized to deploy and maintain robust engineering solutions.
        </p>
    </div>
    
    <div class="w-[100vw] relative left-[50%] right-[50%] -ml-[50vw] -mr-[50vw] border-y border-zinc-300 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 py-0 transition-colors duration-300">
        <div class="carousel-container relative w-full overflow-hidden flex h-28 group/slider">
            <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-32 bg-gradient-to-r from-zinc-50 dark:from-zinc-900 to-transparent"></div>
            <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-32 bg-gradient-to-l from-zinc-50 dark:from-zinc-900 to-transparent"></div>
            
            <button aria-label="Scroll right" class="btn-right group/btn absolute h-full top-0 bottom-0 right-0 z-20 w-12 flex items-center justify-center bg-gradient-to-l from-zinc-200/60 to-transparent dark:from-zinc-800/40 opacity-100 lg:opacity-0 transition-all duration-300 hover:from-blue-300/70 dark:hover:from-blue-900/40 lg:group-hover/slider:opacity-100 cursor-pointer border-none outline-none">
                <svg class="h-6 w-6 text-zinc-500 dark:text-zinc-400 transition-colors duration-300 group-hover/btn:text-blue-600 dark:group-hover/btn:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7" />
                </svg>
            </button>

            <div class="animate-carousel-infra flex w-max items-center h-full">
                {duplicatedInfra.map(tech => (
                    <div class="icon-card group/icon select-none relative flex flex-col items-center justify-center cursor-pointer min-w-[100px] h-full mr-16 transform-gpu [&.is-hovered>div]:-translate-y-3 [&.is-hovered>span]:opacity-100">
                        <div class="pointer-events-none flex h-full w-full items-center justify-center transition-transform duration-300">
                            <div class="h-[48px] w-[48px] bg-gray-400 dark:bg-zinc-600 transition-colors duration-300 [.is-hovered_&]:bg-blue-600 dark:[.is-hovered_&]:bg-blue-400" style={`-webkit-mask-image: url('${tech.icon}'); mask-image: url('${tech.icon}'); -webkit-mask-size: contain; mask-size: contain; -webkit-mask-repeat: no-repeat; mask-repeat: no-repeat; -webkit-mask-position: center; mask-position: center;`}></div>
                        </div>
                        <span class="pointer-events-none absolute bottom-4 text-xs font-bold text-gray-500 dark:text-zinc-400 opacity-0 transition-opacity duration-300">
                            {tech.name}
                        </span>
                    </div>
                ))}
            </div>
        </div>
    </div>

    <div class="mt-12 mb-6">
        <h3 class="text-xl font-bold text-gray-900 dark:text-zinc-200 transition-colors duration-300">
            Versatility & Additional Ecosystems
        </h3>
        <p class="mt-2 text-sm text-gray-600 dark:text-zinc-400 transition-colors duration-300">
            Complementary libraries and frameworks managed for data analysis, graphical rendering, and comprehensive full-stack development.
        </p>
    </div>
    
    <div class="w-[100vw] relative left-[50%] right-[50%] -ml-[50vw] -mr-[50vw] border-y border-zinc-300 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-900 py-0 transition-colors duration-300">
        <div class="carousel-container relative w-full overflow-hidden flex h-28 group/slider">
            <div class="pointer-events-none absolute inset-y-0 left-0 z-10 w-32 bg-gradient-to-r from-zinc-50 dark:from-zinc-900 to-transparent"></div>
            <div class="pointer-events-none absolute inset-y-0 right-0 z-10 w-32 bg-gradient-to-l from-zinc-50 dark:from-zinc-900 to-transparent"></div>
            
            <button aria-label="Scroll left" class="btn-left group/btn absolute h-full top-0 bottom-0 left-0 z-20 w-12 flex items-center justify-center bg-gradient-to-r from-zinc-200/60 to-transparent dark:from-zinc-800/40 opacity-100 lg:opacity-0 transition-all duration-300 hover:from-blue-300/70 dark:hover:from-blue-900/40 lg:group-hover/slider:opacity-100 cursor-pointer border-none outline-none">
                <svg class="h-6 w-6 text-zinc-500 dark:text-zinc-400 transition-colors duration-300 group-hover/btn:text-blue-600 dark:group-hover/btn:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7" />
                </svg>
