---
interface ProjectData {
    title: string;
    category: string;
    description: string;
    extendedDetails: string;
    technologies: string[];
    githubUrl: string;
}

const projects: ProjectData[] = [
    {
        title: 'Async Network Engine',
        category: 'High-Performance Systems',
        description: 'A custom, low-latency network stack and asynchronous server architecture engineered in C.',
        extendedDetails: 'Specifically utilizes epoll for maximizing I/O throughput and implements lock-free data structures to eliminate synchronization overhead. Features custom binary protocol parsing for efficient data transmission relevant to high-frequency systems.',
        technologies: ['C', 'epoll', 'Concurrency', 'Network Architecture'],
        githubUrl: 'https://github.com/iago-fernandez/async-network-engine'
    },
    {
        title: 'Bare-Metal Homelab & Internal Cloud',
        category: 'Infrastructure as Code',
        description: 'Infrastructure as Code deployment for a self-hosted Homelab with strict internal routing isolation.',
        extendedDetails: 'Orchestrates a containerized environment using Docker and Docker Compose, focusing on network security. Service isolation is strictly enforced; a reverse proxy manages internal routing, while remote access is exclusively established via a customized Wireguard tunnel to maintain boundaries against the public internet.',
        technologies: ['Shell', 'Docker', 'Networking', 'Wireguard'],
        githubUrl: 'https://github.com/iago-fernandez/homelab'
    },
    {
        title: '3D Game of Life on Toroidal Board',
        category: 'Concurrent Computing',
        description: 'A modern, highly optimized implementation of Conway\'s Game of Life simulating a wrap-around board.',
        extendedDetails: 'The simulation is rendered in two synchronized views. Focused on computational efficiency, maximizing temporal and spatial performance by optimizing the underlying matrix calculations for the distinct pixel-perfect 2D grid and the algorithmic complexity of the 3D torus visualization.',
        technologies: ['C++', 'Algorithms', 'Optimization', 'Rendering'],
        githubUrl: 'https://github.com/iago-fernandez/3d-game-of-life'
    },
    {
        title: 'DFA Visualizer',
        category: 'Algorithmic Theory',
        description: 'A mathematical tool to define Deterministic Finite Automata (DFAs), validate strings, and visualize the structure.',
        extendedDetails: 'Renders both the static DFA definition and dynamic execution paths using Graphviz, providing clear visual insights into algorithmic execution and strict theoretical computation models.',
        technologies: ['Python', 'Automata Theory', 'Graphviz'],
        githubUrl: 'https://github.com/iago-fernandez/dfa-visualizer'
    },
    {
        title: 'Engineering Portfolio',
        category: 'Frontend Architecture',
        description: 'A statically generated engineering portfolio and technical documentation hub.',
        extendedDetails: 'Designed to showcase system architectures and software projects with a strict focus on build-time efficiency, zero-javascript progressive enhancement, and automated continuous deployment pipelines via Cloudflare Pages.',
        technologies: ['Astro', 'Tailwind CSS', 'SSG', 'CI/CD'],
        githubUrl: 'https://github.com/iago-fernandez/portfolio-website'
    }
];
---

<section id="projects" class="py-20 animate-fade-in-up">
    <h2 class="mb-10 text-3xl font-bold tracking-tight text-gray-900 dark:text-zinc-100 sm:text-4xl transition-colors duration-300">
        Technical Projects
    </h2>
    <div class="grid gap-8 sm:grid-cols-2 items-start">
        {projects.map((project) => (
            <div class="flex flex-col rounded-xl border border-gray-200 dark:border-zinc-700 bg-white dark:bg-zinc-800 p-6 shadow-sm transition-all hover:-tranzinc-y-1 hover:shadow-lg dark:hover:shadow-blue-900/10">
                <div class="mb-4">
                    <span class="text-xs font-bold uppercase tracking-wider text-blue-600 dark:text-blue-400 transition-colors duration-300">
                        {project.category}
                    </span>
                    <h3 class="mt-2 text-xl font-bold text-gray-900 dark:text-zinc-100 transition-colors duration-300">
                        {project.title}
                    </h3>
                </div>
                <p class="mb-4 flex-1 text-sm leading-relaxed text-gray-600 dark:text-zinc-400 transition-colors duration-300">
                    {project.description}
                </p>
                
                <details class="group mb-6">
                    <summary class="flex cursor-pointer items-center text-sm font-semibold text-gray-900 dark:text-zinc-300 transition-colors hover:text-blue-600 dark:hover:text-blue-400 focus:outline-none">
                        <span class="group-open:hidden">View architecture details</span>
                        <span class="hidden group-open:inline">Hide architecture details</span>
                        <svg class="ml-1 h-4 w-4 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </summary>
                    <div class="mt-3 rounded-md bg-gray-50 dark:bg-zinc-900/50 p-4 text-sm text-gray-600 dark:text-zinc-400 border border-gray-100 dark:border-zinc-700 transition-colors duration-300">
                        <p class="leading-relaxed">{project.extendedDetails}</p>
                    </div>
                </details>

                <div class="mb-6 flex flex-wrap gap-2">
                    {project.technologies.map((tech) => (
                        <span class="rounded-md bg-blue-50 dark:bg-zinc-700/50 px-2.5 py-1 text-xs font-bold text-blue-700 dark:text-blue-300 border border-blue-100 dark:border-blue-900/30 transition-colors duration-300">
                            {tech}
                        </span>
                    ))}
                </div>
                <div class="mt-auto pt-4 border-t border-gray-100 dark:border-zinc-700 transition-colors duration-300">
                    <a 
                        href={project.githubUrl}
                        target="_blank"
                        rel="noopener noreferrer" 
                        class="inline-flex items-center text-sm font-bold text-gray-900 dark:text-zinc-300 transition-colors hover:text-blue-600 dark:hover:text-blue-400"
                    >
                        <svg class="mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                            <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                        </svg>
                        View Repository
                    </a>
                </div>
            </div>
        ))}
    </div>
</section>