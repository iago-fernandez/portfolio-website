---
interface ProjectData {
    title: string;
    category: string;
    description: string;
    technologies: string[];
    githubUrl: string;
}

const projects: ProjectData[] = [
    {
        title: 'Async Network Engine',
        category: 'High-Performance Systems',
        description: 'A suite of high-performance network utilities and server architectures. Features custom binary protocol parsing, lock-free data structures, and an event-driven server utilizing epoll for maximum throughput and low latency.',
        technologies: ['C', 'epoll', 'Network Architecture'],
        githubUrl: 'https://github.com/iago-fernandez/async-network-engine'
    },
    {
        title: 'Bare-Metal Homelab & Internal Cloud',
        category: 'Infrastructure as Code',
        description: 'Infrastructure as Code for a self-hosted Homelab. A containerized environment using Docker and Docker Compose to orchestrate network security, private cloud storage, and automated services with strict internal isolation.',
        technologies: ['Shell', 'Docker', 'Networking'],
        githubUrl: 'https://github.com/iago-fernandez/homelab'
    },
    {
        title: '3D Game of Life',
        category: 'Concurrent Computing',
        description: 'A modern implementation of Conway\'s Game of Life with a toroidal board. The simulation is rendered in two synchronized views, optimizing the matrix computations for a pixel-perfect 2D grid and a 3D torus.',
        technologies: ['C++', 'Algorithms', 'Optimization'],
        githubUrl: 'https://github.com/iago-fernandez/3d-game-of-life'
    },
    {
        title: 'DFA Visualizer',
        category: 'Algorithmic Theory',
        description: 'A mathematical tool to define Deterministic Finite Automata (DFAs), validate strings, and visualize both the static structure and dynamic execution paths using Graphviz.',
        technologies: ['Python', 'Automata Theory', 'Graphviz'],
        githubUrl: 'https://github.com/iago-fernandez/dfa-visualizer'
    }
];
---

<section id="projects" class="py-20">
    <div class="animate-fade-in-up">
        <h2 class="mb-10 text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
            Projects & Infrastructure
        </h2>
        <div class="grid gap-8 sm:grid-cols-2">
            {projects.map((project) => (
                <div class="flex flex-col rounded-xl border border-gray-200 bg-white p-6 shadow-sm transition-shadow hover:shadow-md">
                    <div class="mb-4">
                        <span class="text-xs font-bold uppercase tracking-wider text-blue-600">
                            {project.category}
                        </span>
                        <h3 class="mt-2 text-xl font-semibold text-gray-900">
                            {project.title}
                        </h3>
                    </div>
                    <p class="mb-6 flex-1 text-sm leading-relaxed text-gray-600">
                        {project.description}
                    </p>
                    <div class="mb-6 flex flex-wrap gap-2">
                        {project.technologies.map((tech) => (
                            <span class="rounded-md bg-gray-50 px-2.5 py-1 text-xs font-semibold text-gray-600 border border-gray-100">
                                {tech}
                            </span>
                        ))}
                    </div>
                    <div class="mt-auto">
                        <a 
                            href={project.githubUrl}
                            target="_blank"
                            rel="noopener noreferrer" 
                            class="inline-flex items-center text-sm font-medium text-gray-900 transition-colors hover:text-blue-600"
                        >
                            <svg class="mr-2 h-5 w-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd" />
                            </svg>
                            View Repository
                        </a>
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>